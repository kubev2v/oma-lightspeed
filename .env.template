# OMA Lightspeed Environment Variables
# Copy this file to .env and fill in your values

# ─── LLM Provider Configuration ─────────────────────────────────────────────

# Option 1: Gemini API Key (simpler, recommended for local dev)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Option 2: Vertex AI (production-like)
# If using Vertex AI, set GEMINI_API_KEY to "dummy" and provide the service account JSON
# The service account JSON should be placed at: config/vertex-credentials.json

# ─── MCP Server Configuration ───────────────────────────────────────────────

# URL of the Migration Planner API (the OMA backend)
# Use host.containers.internal to reach services on the host from inside containers
# MIGRATION_PLANNER_URL="http://host.containers.internal:3443"

# MCP authentication type: 'none' for local dev, 'forwarded' for production
# AUTH_TYPE="none"

# ─── Optional Overrides ─────────────────────────────────────────────────────

# Override the lightspeed-stack image for local development
# LIGHTSPEED_STACK_IMAGE_OVERRIDE=""

# Override the OMA MCP server image
# OMA_MCP_IMAGE=""
