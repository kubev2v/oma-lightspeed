# Development environment parameter overrides for template.yaml
# These values are used by scripts/generate.sh to create local config files

IMAGE_TAG=latest
LIGHTSPEED_SERVICE_AUTH_ENABLED=false
# For local dev (podman pod), use localhost since containers share network namespace
# For production (OpenShift), use the Service name: http://oma-service-mcp:8000/mcp
MCP_SERVER_URL=http://localhost:8000/mcp
OMA_DEFAULT_MODEL=gemini-2.5-flash
DISABLE_QUERY_SYSTEM_PROMPT=false
SYSTEM_PROMPT_PATH=/tmp/systemprompt.txt
LLAMA_CLIENT_CONFIG_PATH=llama_stack_client_config.yaml
LIGHTSPEED_STACK_POSTGRES_SSL_MODE=disable
LLAMA_STACK_POSTGRES_SSL_MODE=disable

# Empty auth rules for local development (auth is disabled anyway)
AUTHN_ROLE_RULES='[]'
AUTHZ_ACCESS_RULES='[]'

# User data collection: disabled for local dev
LIGHTSPEED_FEEDBACK_ENABLED=false
LIGHTSPEED_TRANSCRIPTS_ENABLED=false
